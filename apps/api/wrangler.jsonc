{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ev-bus-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-18",
  "durable_objects": {
    "bindings": [
      {
        "name": "REALTIME_ROOM",
        "class_name": "RealtimeRoom"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["RealtimeRoom"]
    }
  ],
  "triggers": {
    "crons": ["*/5 * * * *"]
  },
  "vars": {
    "APP_ENV": "development"
  }
}
