# ─── Development environment (.env) ──────────────────────────────────────────
# Copy this to .env and fill in your values.
# Mailpit handles all email in dev — no Brevo key needed.

NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database (Turso)
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-turso-token

# Auth
JWT_SECRET=dev-secret-at-least-24-chars-long

# Storage (optional in dev)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=

# ImageKit (optional in dev)
# IMAGEKIT_PUBLIC_KEY=
# IMAGEKIT_PRIVATE_KEY=
# IMAGEKIT_URL_ENDPOINT=

# ── Email: Mailpit (dev) ──────────────────────────────────────────────────────
# Start Mailpit: docker run -p 1025:1025 -p 8025:8025 axllent/mailpit
# View emails:   http://localhost:8025
MAILPIT_HOST=localhost
MAILPIT_PORT=1025

APP_NAME=Business Chat
APP_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
