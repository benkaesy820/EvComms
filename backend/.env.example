# ─── Environment Settings ──────────────────────────────────────────────
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# ─── Database Configurations (Turso SQLite) ──────────────────────────
# Paste your libSQL or Turso url here (e.g., libsql://my-db.turso.io)
TURSO_DATABASE_URL=
# Paste your Turso Auth Token
TURSO_AUTH_TOKEN=

# ─── Security Settings ────────────────────────────────────────────────
# Use a strong, 32+ character random string
JWT_SECRET=super_secret_jwt_longer_than_32_chars_for_production
JWT_EXPIRY_MINUTES=15
# The domain of the app that issues JWTs
JWT_ISSUER=https://your-domain.sevalla.com
# The name of the app the tokens are for
JWT_AUDIENCE=Business Chat

# ─── Cors & App URLs ──────────────────────────────────────────────────
# Comma-separated or single domain allowed to access API
CORS_ORIGIN=https://your-frontend.sevalla.com
APP_NAME="Business Chat"
APP_URL=https://your-frontend.sevalla.com

# ─── File Uploads Config (AWS S3 / Cloudflare R2) ─────────────────────
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=

# ─── ImageKit Configuration (Optional) ────────────────────────────────
# IMAGEKIT_PUBLIC_KEY=
# IMAGEKIT_PRIVATE_KEY=
# IMAGEKIT_URL_ENDPOINT=

# ─── Email Provider Settings (Brevo / Gmail) ──────────────────────────
EMAIL_PROVIDER=brevo,gmail

BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME="System Notifications"

GMAIL_USER=
GMAIL_APP_PASSWORD=

# ─── Seed Admin (for npm run seed:admin — NEVER use real prod password here) ──
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=Super Admin
