{
  "name": "business-chat-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:once": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json && shx cp config.json dist/",
    "start": "node dist/index.js",
    "db:status": "node --import tsx scripts/status.ts",
    "db:migrate": "node --import tsx scripts/migrate.ts",
    "db:migrate:dry": "node --import tsx scripts/migrate.ts -- --dry",
    "db:migrate:list": "node --import tsx scripts/migrate.ts -- --list",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:reset": "node --import tsx scripts/reset-db.ts",
    "db:reset:full": "node --import tsx scripts/reset-db.ts && drizzle-kit push && node --import tsx scripts/seed-admin.ts",
    "seed:admin": "node --import tsx scripts/seed-admin.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.985.0",
    "@aws-sdk/s3-request-presigner": "^3.985.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^9.4.0",
    "@libsql/client": "^0.17.0",
    "@node-rs/argon2": "^2.0.2",
    "@socket.io/redis-adapter": "^8.3.0",
    "@tursodatabase/sync": "^0.4.4",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.7.4",
    "imagekit": "^6.0.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "lru-cache": "^11.2.6",
    "nodemailer": "^6.9.16",
    "pino": "^9.0.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "ulid": "^2.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.10.6",
    "@types/nodemailer": "^6.4.17",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.9",
    "pino-pretty": "^11.0.0",
    "shx": "^0.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3"
  }
}
