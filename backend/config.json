        "faq": [
            {
                "id": "faq_1",
                "question": "How do I get access to the platform?",
                "answer": "Click \"Get Started Free\" on the homepage and register with your email address. Your account will be reviewed and approved by our team \u2014 this typically takes a few hours. You'll receive an email confirmation once you're approved."
            },
            {
                "id": "faq_2",
                "question": "How does the support chat work?",
                "answer": "Once your account is approved, you'll have a dedicated conversation with our support team. You can send text messages, share images, documents, and videos. Your messages are delivered in real-time and your assigned agent will respond as quickly as possible."
            },
            {
                "id": "faq_3",
                "question": "Can I upload files and images in my messages?",
                "answer": "Yes \u2014 media uploads are available to users who have been granted upload permission by a support agent. Supported formats include JPEG, PNG, GIF, MP4, PDF, Word, and Excel files."
            },
            {
                "id": "faq_4",
                "question": "What happens if my conversation is closed?",
                "answer": "When a support agent closes a conversation, you'll see a banner in the chat with a note from the agent. You can reopen the conversation at any time by clicking \"Reopen conversation\" \u2014 your full message history is always preserved."
            },
            {
                "id": "faq_5",
                "question": "How do I reset my password?",
                "answer": "Go to the login page and click \"Forgot Password\". Enter your registered email address and follow the instructions in the email you receive. Password reset links expire after 30 minutes."
            },
            {
                "id": "faq_6",
                "question": "Is my data secure?",
                "answer": "Yes. All data is transmitted over HTTPS with encrypted connections. Sessions are managed with httpOnly cookies, and we implement CSRF protection, rate limiting, and role-based access controls."
            },
            {
                "id": "faq_7",
                "question": "Can I use the platform on my phone?",
                "answer": "Absolutely. The platform is fully responsive and designed for mobile use. It works on any modern browser on iOS and Android without needing to install an app."
            },
            {
                "id": "faq_8",
                "question": "How do I report a problem with the platform?",
                "answer": "Use the \"User Reports\" section in your account to submit a bug report or platform issue. For urgent matters, send a message directly in your support chat."
            }
        ],
