# ─── App ─────────────────────────────────────────────────────────────────────
VITE_APP_NAME=EvComms

# ─── API & Socket URLs ────────────────────────────────────────────────────────
# Local development (Vite proxies these automatically):
#   VITE_API_URL=http://localhost:3000
#   VITE_SOCKET_URL=http://localhost:3000
#
# Production (set these to your Sevalla backend URL):
VITE_API_URL=https://your-backend.sevalla.app
VITE_SOCKET_URL=https://your-backend.sevalla.app
